# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/unified_legal_db

# AI Model Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b-instruct-q8_0
GEMINI_API_KEY=your_google_gemini_api_key_here
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1
EMBEDDING_DIMENSION=768

# RAG Configuration
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RESULTS=8

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage
UPLOAD_DIR=uploads
ICONS_DIR=icons
DOCUMENTS_DIR=documents

# Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Communication
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@yourlegalfirm.com

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Legal Platform Configuration
FIRM_REGISTRATION_ENABLED=true
CLIENT_SELF_REGISTRATION=true
DEFAULT_CONSULTATION_DURATION=60
DEFAULT_CURRENCY=USD

# Feature Flags
ENABLE_PAYMENTS=true
ENABLE_NOTIFICATIONS=true
ENABLE_CASE_MANAGEMENT=true
ENABLE_DOCUMENT_ANALYSIS=true